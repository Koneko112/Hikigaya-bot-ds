<!DOCTYPE html>
<html>
<head>
    <title>Управление варнами</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .warn-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            margin-top: 24px;
        }
        .warn-card {
            background: #131325;
            border-radius: 16px;
            border: 1px solid #2a2a50;
            padding: 20px 24px;
            transition: 0.3s;
        }
        .warn-card:hover {
            border-color: #fdcb6e;
        }
        .warn-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }
        .warn-header h3 {
            color: #fdcb6e;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .warn-header .count {
            background: rgba(253, 203, 110, 0.15);
            color: #fdcb6e;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
        }
        .warn-empty {
            text-align: center;
            padding: 60px 20px;
            color: #8888aa;
            background: #131325;
            border-radius: 16px;
            border: 1px solid #2a2a50;
        }
        .warn-empty .icon {
            font-size: 4rem;
            display: block;
            margin-bottom: 16px;
        }
        .warn-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
        }
        .warn-table th,
        .warn-table td {
            padding: 10px 12px;
            text-align: left;
            border-bottom: 1px solid #2a2a50;
        }
        .warn-table th {
            color: #8888aa;
            font-size: 0.8rem;
            text-transform: uppercase;
            background: rgba(255, 255, 255, 0.03);
        }
        .warn-table tr:hover td {
            background: rgba(253, 203, 110, 0.03);
        }
        .btn-clear {
            background: #e74c3c;
            color: #fff;
            border: none;
            padding: 6px 16px;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-clear:hover {
            background: #c0392b;
        }
        .user-id {
            color: #8888aa;
            font-size: 0.85rem;
        }
        .moderator-id {
            color: #8888aa;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
            <div class="nav-menu">
                <a href="/dashboard">📊 Панель</a>
                <a href="/profile">👤 Профиль</a>
                <a href="/shop">🛒 Магазин</a>
                <a href="/youtube">📺 YouTube</a>
                <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
                <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <h1>⚠️ Управление варнами</h1>
            <a href="/admin" style="color: #8888aa;">← Назад в админку</a>
        </div>
        <p style="color: #8888aa; margin-bottom: 20px;">Все предупреждения пользователей сервера</p>

        <% 
        // Собираем все варны
        let allWarns = [];
        if (warnings && warnings.guilds) {
            for (const guildId in warnings.guilds) {
                const guild = warnings.guilds[guildId];
                if (guild && guild.users) {
                    for (const userId in guild.users) {
                        const warns = guild.users[userId];
                        if (Array.isArray(warns) && warns.length > 0) {
                            allWarns.push({ userId, warns });
                        }
                    }
                }
            }
        }
        %>

        <% if (allWarns.length === 0) { %>
            <div class="warn-empty">
                <span class="icon">📭</span>
                <p>Нет предупреждений</p>
                <p style="font-size: 0.9rem; margin-top: 8px;">Все пользователи в порядке</p>
            </div>
        <% } else { %>
            <div class="warn-grid">
                <% allWarns.forEach(function(item) { %>
                    <div class="warn-card">
                        <div class="warn-header">
                            <h3>
                                👤 <span><%= item.userId %></span>
                                <span class="count"><%= item.warns.length %> варнов</span>
                            </h3>
                            <form method="POST" action="/api/warnings/clear" style="margin: 0;">
                                <input type="hidden" name="userId" value="<%= item.userId %>">
                                <input type="hidden" name="guildId" value="<%= Object.keys(warnings.guilds)[0] %>">
                                <button type="submit" class="btn-clear">🗑 Очистить все</button>
                            </form>
                        </div>
                        
                        <div style="overflow-x: auto;">
                            <table class="warn-table">
                                <thead>
                                    <tr>
                                        <th>Модератор</th>
                                        <th>Причина</th>
                                        <th>Дата</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% item.warns.forEach(function(w) { %>
                                    <tr>
                                        <td><span class="moderator-id"><%= w.moderator %></span></td>
                                        <td><%= w.reason %></td>
                                        <td><%= new Date(w.timestamp || w.date).toLocaleString() %></td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</body>
</html>