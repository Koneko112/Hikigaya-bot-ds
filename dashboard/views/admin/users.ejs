<!DOCTYPE html>
<html>
<head>
    <title>Управление пользователями</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
            <div class="nav-menu">
    <a href="/dashboard">📊 Панель</a>
    <a href="/profile">👤 Профиль</a>
    <a href="/shop">🛒 Магазин</a>
    <a href="/youtube">📺 YouTube</a>
    <a href="/admin" style="color: #fdcb6e; background: rgba(253, 203, 110, 0.1);">⚙️ Админ</a>
    <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
</div>
        </div>
    </nav>
    <div class="container">
        <h1>👥 Управление пользователями</h1>
        <p><a href="/admin" style="color: #8888aa;">← Назад</a></p>

        <div style="overflow-x: auto; margin-top: 16px;">
            <table style="width: 100%; border-collapse: collapse; background: #131325; border-radius: 16px; overflow: hidden; border: 1px solid #2a2a50;">
                <thead>
                    <tr>
                        <th style="padding: 12px 16px; text-align: left; background: rgba(124, 92, 252, 0.08); color: #8888aa;">ID</th>
                        <th style="padding: 12px 16px; text-align: left; background: rgba(124, 92, 252, 0.08); color: #8888aa;">Баланс</th>
                        <th style="padding: 12px 16px; text-align: left; background: rgba(124, 92, 252, 0.08); color: #8888aa;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td style="padding: 12px 16px; border-bottom: 1px solid #2a2a50;"><code><%= u.id %></code></td>
                            <td style="padding: 12px 16px; border-bottom: 1px solid #2a2a50;"><strong><%= u.balance %></strong></td>
                            <td style="padding: 12px 16px; border-bottom: 1px solid #2a2a50;">
                                <form method="POST" action="/api/admin/economy/add" style="display: inline;">
                                    <input type="hidden" name="userId" value="<%= u.id %>">
                                    <input type="number" name="amount" placeholder="+" style="width: 60px; padding: 4px 8px; background: #0b0b14; border: 1px solid #2a2a50; color: #eee; border-radius: 4px;">
                                    <button type="submit" style="background: #00b894; color: #fff; border: none; padding: 4px 12px; border-radius: 4px; cursor: pointer;">+</button>
                                </form>
                                <form method="POST" action="/api/admin/economy/remove" style="display: inline;">
                                    <input type="hidden" name="userId" value="<%= u.id %>">
                                    <input type="number" name="amount" placeholder="-" style="width: 60px; padding: 4px 8px; background: #0b0b14; border: 1px solid #2a2a50; color: #eee; border-radius: 4px;">
                                    <button type="submit" style="background: #e74c3c; color: #fff; border: none; padding: 4px 12px; border-radius: 4px; cursor: pointer;">−</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    <footer class="footer">
        © <%= new Date().getFullYear() %> Discord Bot Panel
    </footer>
</body>
</html>