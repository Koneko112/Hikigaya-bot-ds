<!DOCTYPE html>
<html>
<head>
    <title>Админ-панель</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 16px;
            margin-top: 20px;
        }
        .admin-card {
            background: #131325;
            border-radius: 12px;
            border: 1px solid #2a2a50;
            padding: 18px 14px;
            text-align: center;
            transition: 0.3s;
            text-decoration: none;
            color: #eee;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }
        .admin-card:hover {
            border-color: #7c5cfc;
            transform: translateY(-3px);
            box-shadow: 0 0 30px rgba(124, 92, 252, 0.08);
        }
        .admin-card .icon {
            font-size: 2.2rem;
            line-height: 1;
        }
        .admin-card .title {
            font-weight: 600;
            font-size: 0.9rem;
        }
        .admin-card .desc {
            color: #8888aa;
            font-size: 0.7rem;
        }
        .admin-card .badge {
            display: inline-block;
            background: rgba(124, 92, 252, 0.1);
            color: #7c5cfc;
            padding: 1px 12px;
            border-radius: 12px;
            font-size: 0.6rem;
            font-weight: 600;
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 14px;
            margin-bottom: 20px;
        }
        .stats-card {
            background: #131325;
            border-radius: 12px;
            border: 1px solid #2a2a50;
            padding: 16px;
            text-align: center;
        }
        .stats-card .number {
            font-size: 1.8rem;
            font-weight: 700;
            color: #7c5cfc;
        }
        .stats-card .label {
            color: #8888aa;
            font-size: 0.8rem;
        }
        @media (max-width: 500px) {
            .admin-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
            <div class="nav-menu">
                <a href="/dashboard">📊 Панель</a>
                <a href="/profile">👤 Профиль</a>
                <a href="/shop">🛒 Магазин</a>
                <a href="/youtube">📺 YouTube</a>
                <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
                <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1>⚙️ Управление сервером</h1>
        <p style="color: #8888aa; margin-bottom: 8px;">Быстрый доступ к основным функциям</p>

        <div class="stats-row">
            <div class="stats-card">
                <div class="number"><%= stats.totalUsers || 0 %></div>
                <div class="label">👥 Пользователей</div>
            </div>
            <div class="stats-card">
                <div class="number"><%= (stats.totalBalance || 0).toLocaleString() %></div>
                <div class="label">💰 Всего монет</div>
            </div>
        </div>

        <div class="admin-grid">
            <a href="/admin/users" class="admin-card">
                <span class="icon">👥</span>
                <div class="title">Пользователи</div>
                <div class="desc">Управление балансом</div>
                <span class="badge"><%= stats.totalUsers || 0 %> чел.</span>
            </a>

            <a href="/admin/all-users" class="admin-card">
                <span class="icon">📋</span>
                <div class="title">Все пользователи</div>
                <div class="desc">Полный список</div>
                <span class="badge">Список</span>
            </a>

            <a href="/warnings" class="admin-card">
                <span class="icon">⚠️</span>
                <div class="title">Варны</div>
                <div class="desc">Предупреждения</div>
                <span class="badge">Управление</span>
            </a>

            <a href="/admin/moderation" class="admin-card">
                <span class="icon">🔨</span>
                <div class="title">Модерация</div>
                <div class="desc">Мут, бан, роли</div>
                <span class="badge">Действия</span>
            </a>

            <a href="/admin/youtube" class="admin-card">
                <span class="icon">📺</span>
                <div class="title">YouTube</div>
                <div class="desc">Управление каналами</div>
                <span class="badge">Отслеживание</span>
            </a>

            <a href="/admin/roles" class="admin-card">
                <span class="icon">🎭</span>
                <div class="title">Роли сайта</div>
                <div class="desc">Управление правами</div>
                <span class="badge">Доступ</span>
            </a>

            <a href="/admin/create-role" class="admin-card">
                <span class="icon">🎨</span>
                <div class="title">Создать роль</div>
                <div class="desc">Для Discord и магазина</div>
                <span class="badge">Новая</span>
            </a>

            <a href="/admin/give-role" class="admin-card">
                <span class="icon">🎯</span>
                <div class="title">Выдать роль</div>
                <div class="desc">Платные роли</div>
                <span class="badge">Доступ</span>
            </a>

            <a href="/admin/role-purchases" class="admin-card">
                <span class="icon">📊</span>
                <div class="title">Покупки ролей</div>
                <div class="desc">История выдач</div>
                <span class="badge">Статистика</span>
            </a>

            <a href="/admin/settings" class="admin-card">
                <span class="icon">⚙️</span>
                <div class="title">Настройки</div>
                <div class="desc">Конфигурация бота</div>
                <span class="badge">Система</span>
            </a>
        </div>
    </div>
</body>
</html>
