<!DOCTYPE html>
<html>
<head>
    <title>Модерация</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .moderation-container {
            display: flex;
            gap: 24px;
            align-items: flex-start;
            flex-wrap: wrap;
        }
        .user-list {
            flex: 1;
            min-width: 300px;
            background: #131325;
            border-radius: 16px;
            border: 1px solid #2a2a50;
            padding: 20px;
            max-height: 600px;
            overflow-y: auto;
        }
        .user-list::-webkit-scrollbar {
            width: 6px;
        }
        .user-list::-webkit-scrollbar-thumb {
            background: #2a2a50;
            border-radius: 3px;
        }
        .user-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 12px;
            border-bottom: 1px solid #2a2a50;
            transition: 0.2s;
        }
        .user-item:hover {
            background: rgba(124, 92, 252, 0.05);
        }
        .user-item .info {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .user-item .info img {
            width: 36px;
            height: 36px;
            border-radius: 50%;
        }
        .user-item .info .name {
            font-weight: 500;
        }
        .user-item .info .id {
            color: #8888aa;
            font-size: 0.7rem;
        }
        .user-item .actions {
            display: flex;
            gap: 6px;
        }
        .user-item .actions .btn-mute {
            background: #fdcb6e;
            color: #111;
            border: none;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.75rem;
            text-decoration: none;
        }
        .user-item .actions .btn-ban {
            background: #e74c3c;
            color: #fff;
            border: none;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.75rem;
            text-decoration: none;
        }
        .user-item .actions .btn-mute:hover {
            background: #fdcb6ecc;
        }
        .user-item .actions .btn-ban:hover {
            background: #c0392b;
        }
        .search-box {
            width: 100%;
            padding: 10px 14px;
            margin-bottom: 16px;
            background: #0b0b14;
            border: 1px solid #2a2a50;
            border-radius: 8px;
            color: #eee;
            font-size: 0.95rem;
        }
        .search-box:focus {
            outline: none;
            border-color: #7c5cfc;
        }
        .empty-state {
            text-align: center;
            color: #8888aa;
            padding: 20px 0;
        }
        .moderation-actions {
            flex: 0 0 320px;
            background: #131325;
            border-radius: 16px;
            border: 1px solid #2a2a50;
            padding: 20px;
        }
        .moderation-actions h3 {
            margin-bottom: 16px;
            color: #fdcb6e;
        }
        .moderation-actions input,
        .moderation-actions select {
            width: 100%;
            padding: 8px 12px;
            margin-bottom: 10px;
            background: #0b0b14;
            border: 1px solid #2a2a50;
            border-radius: 6px;
            color: #eee;
        }
        .moderation-actions button {
            background: #7c5cfc;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            font-weight: 600;
        }
        .moderation-actions button:hover {
            background: #9b7cff;
        }
        .moderation-actions .btn-mute-action {
            background: #fdcb6e;
            color: #111;
        }
        .moderation-actions .btn-mute-action:hover {
            background: #fdcb6ecc;
        }
        .moderation-actions .btn-ban-action {
            background: #e74c3c;
            color: #fff;
        }
        .moderation-actions .btn-ban-action:hover {
            background: #c0392b;
        }
        .result-msg {
            margin-top: 8px;
            color: #8888aa;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
            <div class="nav-menu">
                <a href="/dashboard">📊 Панель</a>
                <a href="/profile">👤 Профиль</a>
                <a href="/shop">🛒 Магазин</a>
                <a href="/youtube">📺 YouTube</a>
                <% if (user && (user.id === '629216255873908736' || user.id === '1091889146265604117')) { %>
                    <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
                <% } %>
                <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1>🔨 Модерация</h1>
        <p style="color: #8888aa; margin-bottom: 16px;">
            Выберите пользователя и выполните действие
        </p>

        <div class="moderation-container">
            <!-- СПИСОК ПОЛЬЗОВАТЕЛЕЙ -->
            <div class="user-list">
                <input type="text" id="searchInput" class="search-box" placeholder="🔍 Поиск по имени или ID...">
                
                <div id="userList">
                    <% members.forEach(m => { %>
                        <div class="user-item" data-name="<%= m.username.toLowerCase() %>" data-id="<%= m.id %>">
                            <div class="info">
                                <img src="<%= m.avatar %>" alt="Аватар">
                                <div>
                                    <div class="name"><%= m.username %></div>
                                    <div class="id"><%= m.id %></div>
                                </div>
                            </div>
                            <div class="actions">
                                <% if (canMute) { %>
                                    <button class="btn-mute" onclick="fillMute('<%= m.id %>', '<%= m.username %>')">🔇 Мут</button>
                                <% } %>
                                <% if (canBan) { %>
                                    <button class="btn-ban" onclick="fillBan('<%= m.id %>', '<%= m.username %>')">🔨 Бан</button>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>

            <!-- ФОРМЫ ДЛЯ ДЕЙСТВИЙ -->
            <div class="moderation-actions">
                <% if (canMute) { %>
                    <h3>🔇 Мут</h3>
                    <form id="muteForm">
                        <input type="text" id="muteUserId" placeholder="ID пользователя" readonly style="cursor: not-allowed; opacity: 0.7;">
                        <input type="text" id="muteDuration" placeholder="Длительность (10m, 1h, 1d)">
                        <input type="text" id="muteReason" placeholder="Причина (необязательно)">
                        <button type="submit" class="btn-mute-action">🔇 Замутить</button>
                    </form>
                    <div id="muteResult" class="result-msg"></div>
                <% } %>

                <% if (canBan) { %>
                    <h3 style="margin-top: 20px; color: #e74c3c;">🔨 Бан</h3>
                    <form id="banForm">
                        <input type="text" id="banUserId" placeholder="ID пользователя" readonly style="cursor: not-allowed; opacity: 0.7;">
                        <input type="text" id="banReason" placeholder="Причина (необязательно)">
                        <button type="submit" class="btn-ban-action">🔨 Забанить</button>
                    </form>
                    <div id="banResult" class="result-msg"></div>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        // ===== ПОИСК =====
        document.getElementById('searchInput').addEventListener('input', function() {
            const query = this.value.toLowerCase();
            const items = document.querySelectorAll('.user-item');
            items.forEach(item => {
                const name = item.dataset.name;
                const id = item.dataset.id;
                if (name.includes(query) || id.includes(query)) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
        });

        // ===== ЗАПОЛНЕНИЕ ФОРМЫ МУТА =====
        function fillMute(userId, username) {
            document.getElementById('muteUserId').value = userId;
            document.getElementById('muteUserId').placeholder = username;
            document.getElementById('muteDuration').focus();
        }

        // ===== ЗАПОЛНЕНИЕ ФОРМЫ БАНА =====
        function fillBan(userId, username) {
            document.getElementById('banUserId').value = userId;
            document.getElementById('banUserId').placeholder = username;
            document.getElementById('banReason').focus();
        }

        // ===== ОТПРАВКА МУТА =====
        document.getElementById('muteForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const result = document.getElementById('muteResult');
            const userId = document.getElementById('muteUserId').value.trim();
            const duration = document.getElementById('muteDuration').value.trim();
            const reason = document.getElementById('muteReason').value.trim();

            if (!userId) {
                result.textContent = '❌ Выберите пользователя из списка';
                result.style.color = '#ff6b6b';
                return;
            }

            if (!duration) {
                result.textContent = '❌ Укажите длительность (10m, 1h, 1d)';
                result.style.color = '#ff6b6b';
                return;
            }

            result.textContent = '⏳ Отправка...';
            result.style.color = '#8888aa';

            try {
                const response = await fetch('/api/admin/mute', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, duration, reason: reason || 'Не указана' })
                });
                const json = await response.json();
                result.textContent = json.success ? '✅ ' + json.message : '❌ ' + json.error;
                result.style.color = json.success ? '#00b894' : '#ff6b6b';
            } catch (error) {
                result.textContent = '❌ Ошибка соединения';
                result.style.color = '#ff6b6b';
            }
        });

        // ===== ОТПРАВКА БАНА =====
        document.getElementById('banForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const result = document.getElementById('banResult');
            const userId = document.getElementById('banUserId').value.trim();
            const reason = document.getElementById('banReason').value.trim();

            if (!userId) {
                result.textContent = '❌ Выберите пользователя из списка';
                result.style.color = '#ff6b6b';
                return;
            }

            result.textContent = '⏳ Отправка...';
            result.style.color = '#8888aa';

            try {
                const response = await fetch('/api/admin/ban', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, reason: reason || 'Не указана' })
                });
                const json = await response.json();
                result.textContent = json.success ? '✅ ' + json.message : '❌ ' + json.error;
                result.style.color = json.success ? '#00b894' : '#ff6b6b';
            } catch (error) {
                result.textContent = '❌ Ошибка соединения';
                result.style.color = '#ff6b6b';
            }
        });
    </script>
</body>
</html>
