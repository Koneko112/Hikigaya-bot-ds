<!DOCTYPE html>
<html>
<head>
    <title>Все пользователи</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .users-grid {
            display: grid;
            gap: 12px;
            margin-top: 20px;
        }
        .user-card {
            background: #131325;
            border-radius: 12px;
            border: 1px solid #2a2a50;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: 0.3s;
            flex-wrap: wrap;
            gap: 12px;
        }
        .user-card:hover {
            border-color: #7c5cfc;
            transform: translateX(4px);
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 14px;
            flex: 1;
            min-width: 180px;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }
        .user-name {
            font-weight: 600;
        }
        .user-id {
            color: #8888aa;
            font-size: 0.75rem;
        }
        .user-roles {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            flex: 1;
            min-width: 150px;
        }
        .role-tag {
            font-size: 0.7rem;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 500;
            white-space: nowrap;
            border: 1px solid transparent;
        }
        .user-joined {
            color: #555;
            font-size: 0.75rem;
            white-space: nowrap;
            min-width: 90px;
            text-align: right;
        }
        .user-joined span {
            color: #8888aa;
        }
        .badge-dev {
            background: rgba(255, 107, 107, 0.15);
            color: #ff6b6b;
            padding: 2px 12px;
            border-radius: 12px;
            font-size: 0.65rem;
            font-weight: 600;
            margin-left: 8px;
        }
        .badge-staff {
            background: rgba(124, 92, 252, 0.15);
            color: #7c5cfc;
            padding: 2px 12px;
            border-radius: 12px;
            font-size: 0.65rem;
            font-weight: 600;
            margin-left: 8px;
        }
        .btn-role {
            background: #7c5cfc;
            color: #fff;
            border: none;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.7rem;
            white-space: nowrap;
        }
        .btn-role:hover {
            background: #9b7cff;
        }
        .search-box {
            padding: 8px 16px;
            background: #0b0b14;
            border: 1px solid #2a2a50;
            border-radius: 8px;
            color: #eee;
            font-size: 0.9rem;
            min-width: 200px;
        }
        .search-box:focus {
            outline: none;
            border-color: #7c5cfc;
        }
        .filter-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }
        .filter-row select {
            padding: 8px 12px;
            background: #0b0b14;
            border: 1px solid #2a2a50;
            border-radius: 8px;
            color: #eee;
        }
        /* Модальное окно */
        #roleModal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }
        #roleModal .modal-content {
            background: #131325;
            border-radius: 16px;
            padding: 30px;
            max-width: 400px;
            width: 90%;
            border: 1px solid #2a2a50;
        }
        #roleModal .modal-content h3 {
            margin-bottom: 8px;
        }
        #roleModal .modal-content p {
            color: #8888aa;
            margin-bottom: 16px;
        }
        #roleModal .modal-content label {
            color: #8888aa;
            font-size: 0.9rem;
        }
        #roleModal .modal-content select {
            width: 100%;
            padding: 10px;
            background: #0b0b14;
            border: 1px solid #2a2a50;
            border-radius: 8px;
            color: #eee;
            margin-top: 4px;
        }
        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
        .modal-actions .btn-save {
            flex: 1;
            background: #7c5cfc;
            color: #fff;
            border: none;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
        }
        .modal-actions .btn-save:hover {
            background: #9b7cff;
        }
        .modal-actions .btn-cancel {
            flex: 1;
            background: #2a2a4a;
            color: #fff;
            border: none;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
        }
        .modal-actions .btn-cancel:hover {
            background: #3a3a5a;
        }
        #modalResult {
            margin-top: 12px;
            color: #8888aa;
            text-align: center;
        }
        @media (max-width: 768px) {
            .user-card {
                flex-direction: column;
                align-items: stretch;
            }
            .user-info {
                min-width: unset;
            }
            .user-roles {
                min-width: unset;
            }
            .user-joined {
                text-align: left;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
            <div class="nav-menu">
                <a href="/dashboard">📊 Панель</a>
                <a href="/profile">👤 Профиль</a>
                <a href="/shop">🛒 Магазин</a>
                <a href="/youtube">📺 YouTube</a>
                <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
                <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="stats-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; margin-bottom: 8px;">
            <div>
                <h1 style="margin-bottom: 4px;">👥 Все пользователи</h1>
                <p style="color: #8888aa;">Всего участников: <strong><%= members.length %></strong></p>
            </div>
            <div class="filter-row">
                <input type="text" id="searchInput" class="search-box" placeholder="🔍 Поиск по имени...">
                <select id="roleFilter">
                    <option value="all">Все роли</option>
                </select>
            </div>
        </div>

        <div class="users-grid" id="usersContainer">
            <% members.forEach(m => { %>
                <div class="user-card" data-name="<%= m.username.toLowerCase() %>" data-roles="<%= m.roles %>">
                    <div class="user-info">
                        <img src="<%= m.avatar %>" alt="<%= m.username %>" class="user-avatar" loading="lazy">
                        <div>
                            <div class="user-name">
                                <%= m.username %>
                                <% if (m.roles.includes('Разработчик')) { %>
                                    <span class="badge-dev">DEV</span>
                                <% } else if (m.roles.includes('Staff') || m.roles.includes('Модератор')) { %>
                                    <span class="badge-staff">STAFF</span>
                                <% } %>
                            </div>
                            <div class="user-id"><%= m.id %></div>
                        </div>
                    </div>

                    <div class="user-roles">
                        <% 
                        const roleList = m.roles.split(', ');
                        const colors = ['#7c5cfc', '#fdcb6e', '#ff6b6b', '#00b894', '#4ecdc4', '#a29bfe', '#fd79a8', '#55efc4', '#74b9ff'];
                        %>
                        <% roleList.forEach((role, index) => { %>
                            <% if (role !== '@everyone') { %>
                                <span class="role-tag" style="background: <%= colors[index % colors.length] %>20; color: <%= colors[index % colors.length] %>; border-color: <%= colors[index % colors.length] %>40;">
                                    <%= role %>
                                </span>
                            <% } %>
                        <% }); %>
                        <% if (roleList.length === 1 && roleList[0] === '@everyone') { %>
                            <span style="color: #555; font-size: 0.75rem;">Нет ролей</span>
                        <% } %>
                    </div>

                    <button class="btn-role" onclick="openRoleModal('<%= m.id %>', '<%= m.username %>')">🎭 Роль</button>

                    <div class="user-joined">
                        🕐 <span><%= new Date(m.joinedAt).toLocaleDateString('ru-RU') %></span>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>

    <!-- МОДАЛЬНОЕ ОКНО -->
    <div id="roleModal">
        <div class="modal-content">
            <h3>🎭 Сменить роль</h3>
            <p>Пользователь: <strong id="modalUserName"></strong></p>
            <input type="hidden" id="modalUserId">
            
            <label>Выберите роль:</label>
            <select id="modalRoleSelect">
                <option value="none">🚫 Без роли</option>
            </select>
            
            <div class="modal-actions">
                <button class="btn-save" onclick="saveRole()">💾 Сохранить</button>
                <button class="btn-cancel" onclick="closeModal()">❌ Отмена</button>
            </div>
            <div id="modalResult"></div>
        </div>
    </div>

    <script>
        // ===== ЗАГРУЗКА РОЛЕЙ =====
        let rolesList = [];

        async function loadRoles() {
            try {
                const res = await fetch('/api/guild-roles');
                const data = await res.json();
                if (data.success) {
                    rolesList = data.roles;
                }
            } catch (e) {
                console.error('Ошибка загрузки ролей:', e);
            }
        }
        loadRoles();

        // ===== ПОИСК =====
        document.getElementById('searchInput').addEventListener('input', function() {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.user-card').forEach(card => {
                card.style.display = card.dataset.name.includes(query) ? 'flex' : 'none';
            });
        });

        // ===== ФИЛЬТР ПО РОЛЯМ =====
        const roleFilter = document.getElementById('roleFilter');
        const allRoles = new Set();
        document.querySelectorAll('.user-card').forEach(card => {
            card.dataset.roles.split(', ').forEach(r => { if (r !== '@everyone') allRoles.add(r); });
        });
        allRoles.forEach(role => {
            const opt = document.createElement('option');
            opt.value = role;
            opt.textContent = role;
            roleFilter.appendChild(opt);
        });

        roleFilter.addEventListener('change', function() {
            const selected = this.value;
            document.querySelectorAll('.user-card').forEach(card => {
                if (selected === 'all') {
                    card.style.display = 'flex';
                    return;
                }
                card.style.display = card.dataset.roles.split(', ').includes(selected) ? 'flex' : 'none';
            });
        });

        // ===== МОДАЛЬНОЕ ОКНО =====
        function openRoleModal(userId, userName) {
            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalUserName').textContent = userName;
            
            const select = document.getElementById('modalRoleSelect');
            select.innerHTML = '<option value="none">🚫 Без роли</option>';
            
            rolesList.forEach(role => {
                const option = document.createElement('option');
                option.value = role.id;
                option.textContent = role.name;
                if (role.color) option.style.color = role.color;
                select.appendChild(option);
            });
            
            document.getElementById('roleModal').style.display = 'flex';
            document.getElementById('modalResult').textContent = '';
        }

        function closeModal() {
            document.getElementById('roleModal').style.display = 'none';
        }

        async function saveRole() {
            const userId = document.getElementById('modalUserId').value;
            const roleId = document.getElementById('modalRoleSelect').value;
            const result = document.getElementById('modalResult');
            
            result.textContent = '⏳ Сохранение...';
            result.style.color = '#8888aa';
            
            try {
                const res = await fetch('/api/admin/set-role', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId, roleId })
                });
                const data = await res.json();
                
                result.textContent = data.success ? '✅ ' + data.message : '❌ ' + data.error;
                result.style.color = data.success ? '#00b894' : '#ff6b6b';
                
                if (data.success) {
                    setTimeout(() => {
                        closeModal();
                        location.reload();
                    }, 1500);
                }
            } catch (e) {
                result.textContent = '❌ Ошибка соединения';
                result.style.color = '#ff6b6b';
            }
        }

        // ===== ЗАКРЫТИЕ ПО КЛИКУ ВНЕ МОДАЛКИ =====
        document.getElementById('roleModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>
