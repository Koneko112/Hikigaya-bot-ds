<!DOCTYPE html>
<html>
<head>
    <title>YouTube</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
           <div class="nav-menu">
    <a href="/dashboard">📊 Панель</a>
    <a href="/profile">👤 Профиль</a>
    <a href="/shop">🛒 Магазин</a>
    <a href="/youtube">📺 YouTube</a>
    <% if (user && user.id === '629216255873908736') { %>
        <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
    <% } %>
    <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
</div>
        </div>
    </nav>
    <div class="container">
        <h1>📺 Отслеживание YouTube</h1>
        <p style="color: #8888aa;">Бот уведомляет о новых видео на этих каналах.</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px;">
            <% if (channels.length > 0) { %>
                <% channels.forEach(channel => { %>
                    <div style="background: #131325; padding: 20px; border-radius: 16px; border: 1px solid #2a2a50;">
                        <h3 style="color: #ff0000; margin-bottom: 8px;">📹 <%= channel.channelName %></h3>
                        <p style="color: #8888aa; font-size: 0.85rem;"><strong>ID:</strong> <code><%= channel.channelId %></code></p>
                        <p style="color: #8888aa; font-size: 0.85rem;">
                            <strong>Последнее видео:</strong>
                            <% if (channel.lastVideoId) { %>
                                <a href="https://www.youtube.com/watch?v=<%= channel.lastVideoId %>" target="_blank">Смотреть</a>
                            <% } else { %>
                                <span style="color: #555;">Нет видео</span>
                            <% } %>
                        </p>
                        <p style="color: #555; font-size: 0.75rem; margin-top: 8px;">
                            Добавлен: <%= new Date(channel.addedAt || Date.now()).toLocaleDateString('ru-RU') %>
                        </p>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="color: #8888aa; grid-column: 1 / -1; text-align: center;">📭 Нет отслеживаемых каналов</p>
            <% } %>
        </div>
    </div>
    <footer class="footer">
        © <%= new Date().getFullYear() %> Discord Bot Panel
    </footer>
</body>
</html>