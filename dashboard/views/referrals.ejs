<%
const title = 'Реферальная система';
%>

<h1>📨 Реферальная система</h1>
<p style="color: var(--text-secondary); margin-bottom: 20px;">
    Приглашай друзей и получай бонусы за каждого нового участника!
</p>

<div class="card">
    <h3>🔗 Твоя реферальная ссылка</h3>
    <p style="background: var(--bg-dark); padding: 12px 16px; border-radius: 8px; margin: 10px 0; word-break: break-all;">
        <code><%= refCode ? `https://discord.gg/invite/ваш_сервер?ref=${refCode}` : 'Создайте код в боте' %></code>
    </p>
    <button onclick="navigator.clipboard.writeText('<%= `https://discord.gg/invite/ваш_сервер?ref=${refCode}` %>')" class="btn btn-sm">
        📋 Скопировать
    </button>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <h3>👥 Приглашено</h3>
        <p><%= invited.length %></p>
    </div>
    <div class="stat-card">
        <h3>💰 Бонусов получено</h3>
        <p><%= reward %></p>
    </div>
</div>

<% if (invited.length > 0) { %>
    <h3 style="margin-top: 20px;">Список приглашённых</h3>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Пользователь</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
            <% invited.forEach((user, index) => { %>
                <tr>
                    <td><%= index + 1 %></td>
                    <td><%= user.username || user.id %></td>
                    <td><%= new Date(user.joinedAt).toLocaleDateString('ru-RU') %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
<% } %>