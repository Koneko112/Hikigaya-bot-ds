<!DOCTYPE html>
<html>
<head>
    <title>Магазин</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
           <div class="nav-menu">
    <a href="/dashboard">📊 Панель</a>
    <a href="/profile">👤 Профиль</a>
    <a href="/shop">🛒 Магазин</a>
    <a href="/youtube">📺 YouTube</a>
    <% if (user && user.id === '629216255873908736') { %>
        <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
    <% } %>
    <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
</div>
        </div>
    </nav>
    <div class="container">
        <h1>🛒 Магазин</h1>
        <p style="color: #8888aa;">Твой баланс: <strong style="color: #7c5cfc;"><%= balance %></strong> монет</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-top: 20px;">
            <% if (items.length > 0) { %>
                <% items.forEach(item => { %>
                    <div style="background: #131325; padding: 20px; border-radius: 16px; border: 1px solid #2a2a50; text-align: center;">
                        <div style="font-size: 2.5rem;"><%= item.emoji || '🎁' %></div>
                        <h4><%= item.name %></h4>
                        <p style="color: #8888aa; font-size: 0.9rem;"><%= item.description || '' %></p>
                        <div style="font-size: 1.2rem; font-weight: 700; color: #fdcb6e; margin: 8px 0;"><%= item.price %> монет</div>
                        <form method="POST" action="/api/shop/buy">
                            <input type="hidden" name="itemId" value="<%= item.id %>">
                            <button type="submit" style="background: #7c5cfc; color: #fff; border: none; padding: 8px 20px; border-radius: 30px; cursor: pointer;" <%= balance < item.price ? 'disabled' : '' %>>
                                <%= balance < item.price ? '❌ Не хватает' : '✅ Купить' %>
                            </button>
                        </form>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="color: #8888aa; grid-column: 1 / -1; text-align: center;">📭 Магазин пуст</p>
            <% } %>
        </div>
<!-- ===== РОЛИ ===== -->
<h2 style="margin-top: 32px;">🎭 Роли</h2>
<div class="shop-grid">
    <% if (shop.roles && shop.roles.length > 0) { %>
        <% shop.roles.forEach(role => { %>
            <div class="shop-item">
                <div class="emoji" style="color: <%= role.color || '#fff' %>">🎭</div>
                <h4><%= role.name %></h4>
                <p style="color: #8888aa; font-size: 0.9rem;">Цвет: <span style="color: <%= role.color || '#fff' %>;"><%= role.color || 'Белый' %></span></p>
                <p class="price"><%= role.price %> монет</p>
                <form method="POST" action="/api/shop/buy-role" style="background: none; padding: 0; border: none; margin: 0;">
                    <input type="hidden" name="roleId" value="<%= role.id %>">
                    <button type="submit" class="btn btn-success btn-sm" <%= balance < role.price ? 'disabled' : '' %>>
                        <%= balance < role.price ? '❌ Не хватает' : '✅ Купить роль' %>
                    </button>
                </form>
            </div>
        <% }); %>
    <% } else { %>
        <p style="grid-column: 1 / -1; text-align: center; color: var(--text-secondary);">
            📭 Ролей пока нет
        </p>
    <% } %>
</div>
    </div>
    <footer class="footer">
        © <%= new Date().getFullYear() %> Discord Bot Panel
    </footer>
</body>
</html>
