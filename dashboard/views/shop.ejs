<!DOCTYPE html>
<html>
<head>
    <title>Магазин</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">🤖 BotPanel</a>
           <div class="nav-menu">
    <a href="/dashboard">📊 Панель</a>
    <a href="/profile">👤 Профиль</a>
    <a href="/shop">🛒 Магазин</a>
    <a href="/youtube">📺 YouTube</a>
    <% if (user && user.id === '629216255873908736') { %>
        <a href="/admin" style="color: #fdcb6e;">⚙️ Админ</a>
    <% } %>
    <a href="/logout" style="color: #ff6b6b;">🚪 Выйти</a>
</div>
        </div>
    </nav>
    <div class="container">
        <h1>🛒 Магазин</h1>
        <p style="color: #8888aa;">Твой баланс: <strong style="color: #7c5cfc;"><%= balance %></strong> монет</p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-top: 20px;">
            <% if (items.length > 0) { %>
                <% items.forEach(item => { %>
                    <div style="background: #131325; padding: 20px; border-radius: 16px; border: 1px solid #2a2a50; text-align: center;">
                        <div style="font-size: 2.5rem;"><%= item.emoji || '🎁' %></div>
                        <h4><%= item.name %></h4>
                        <p style="color: #8888aa; font-size: 0.9rem;"><%= item.description || '' %></p>
                        <div style="font-size: 1.2rem; font-weight: 700; color: #fdcb6e; margin: 8px 0;"><%= item.price %> монет</div>
                        <form method="POST" action="/api/shop/buy">
                            <input type="hidden" name="itemId" value="<%= item.id %>">
                            <button type="submit" style="background: #7c5cfc; color: #fff; border: none; padding: 8px 20px; border-radius: 30px; cursor: pointer;" <%= balance < item.price ? 'disabled' : '' %>>
                                <%= balance < item.price ? '❌ Не хватает' : '✅ Купить' %>
                            </button>
                        </form>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="color: #8888aa; grid-column: 1 / -1; text-align: center;">📭 Магазин пуст</p>
            <% } %>
        </div>
<!-- ===== РОЛИ ===== -->
<h2 style="margin-top: 40px; font-size: 1.6rem; display: flex; align-items: center; gap: 12px;">
    <span>🎭</span> Роли
    <span style="font-size: 0.8rem; color: #8888aa; font-weight: normal;">Выбери свою уникальную роль</span>
</h2>

<div class="roles-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 16px;">
    <% if (roles && roles.length > 0) { %>
        <% roles.forEach(role => { %>
            <div class="role-card" style="
                background: linear-gradient(145deg, #1a1a2e, #131325);
                border-radius: 16px;
                border: 2px solid <%= role.color || '#2a2a50' %>;
                padding: 24px 16px 20px;
                text-align: center;
                transition: all 0.3s ease;
                position: relative;
                overflow: hidden;
                box-shadow: 0 4px 20px rgba(0,0,0,0.3);
                cursor: default;
            "
            onmouseenter="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 12px 40px rgba(124,92,252,0.2)'; this.style.borderColor='#7c5cfc'"
            onmouseleave="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.3)'; this.style.borderColor='<%= role.color || '#2a2a50' %>'">
                
                <!-- Цветной акцент сверху -->
                <div style="position: absolute; top: 0; left: 0; right: 0; height: 4px; background: <%= role.color || '#7c5cfc' %>;"></div>
                
                <!-- Иконка роли -->
                <div style="
                    font-size: 2.8rem;
                    margin-bottom: 8px;
                    display: inline-block;
                    width: 60px;
                    height: 60px;
                    line-height: 60px;
                    border-radius: 50%;
                    background: <%= role.color || '#7c5cfc' %>20;
                    border: 2px solid <%= role.color || '#7c5cfc' %>40;
                ">🎭</div>
                
                <!-- Название -->
                <h4 style="font-size: 1.15rem; margin: 8px 0 4px; color: #fff; font-weight: 600;">
                    <%= role.name %>
                </h4>
                
                <!-- Цвет -->
                <div style="display: flex; justify-content: center; align-items: center; gap: 8px; margin: 4px 0 12px;">
                    <span style="color: #8888aa; font-size: 0.8rem;">Цвет:</span>
                    <span style="display: inline-block; width: 18px; height: 18px; border-radius: 50%; background: <%= role.color || '#99aab5' %>; border: 1px solid #2a2a50;"></span>
                    <span style="color: <%= role.color || '#99aab5' %>; font-weight: 500; font-size: 0.85rem;"><%= role.color || 'Белый' %></span>
                </div>
                
                <!-- Цена -->
                <div style="font-size: 1.3rem; font-weight: 700; color: #fdcb6e; margin: 8px 0 16px;">
                    <%= role.price %> <span style="font-size: 0.9rem; color: #8888aa;">монет</span>
                </div>
                
                <!-- Кнопка покупки -->
                <form method="POST" action="/api/shop/buy-role" style="background: none; padding: 0; border: none; margin: 0;">
                    <input type="hidden" name="roleId" value="<%= role.id %>">
                    <button type="submit" 
                        style="
                            background: <%= balance < role.price ? '#2a2a4a' : role.color || '#7c5cfc' %>;
                            color: <%= balance < role.price ? '#8888aa' : '#fff' %>;
                            border: none;
                            padding: 10px 24px;
                            border-radius: 30px;
                            font-weight: 600;
                            font-size: 0.9rem;
                            cursor: <%= balance < role.price ? 'not-allowed' : 'pointer' %>;
                            transition: all 0.3s ease;
                            width: 100%;
                            opacity: <%= balance < role.price ? '0.5' : '1' %>;
                        "
                        <%= balance < role.price ? 'disabled' : '' %>
                        onmouseenter="if (!this.disabled) { this.style.transform='scale(1.03)'; this.style.boxShadow='0 0 30px <%= role.color || '#7c5cfc' %>40'; }"
                        onmouseleave="if (!this.disabled) { this.style.transform='scale(1)'; this.style.boxShadow='none'; }"
                    >
                        <%= balance < role.price ? '❌ Не хватает' : '✅ Купить роль' %>
                    </button>
                </form>
                
                <!-- Статус (если роль уже есть) -->
                <% 
                // Проверка, есть ли у пользователя эта роль
                // Это нужно будет передать из сервера
                %>
            </div>
        <% }); %>
    <% } else { %>
        <p style="grid-column: 1 / -1; text-align: center; color: var(--text-secondary); padding: 40px 0;">
            📭 Ролей пока нет в магазине
        </p>
    <% } %>
</div>
    </div>
    <footer class="footer">
        © <%= new Date().getFullYear() %> Discord Bot Panel
    </footer>
</body>
</html>
